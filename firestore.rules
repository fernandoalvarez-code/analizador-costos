/**
 * @fileoverview Firestore Security Rules for Analizador de Costos de Corte application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each user can only access their own data,
 * and no data is publicly accessible without authentication.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. Only the user themselves can read and write their profile.
 * - /users/{userId}/cuttingToolAnalyses/{cuttingToolAnalysisId}: Stores cutting tool analysis cases for each user.
 *   Only the user who owns the analysis case can read, write, update, or delete it.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied to prevent unauthorized access to user data.
 * - Path-based ownership is enforced for all user-specific data, simplifying rules and improving performance.
 *
 * Denormalization for Authorization:
 * - The `userId` field is present in the `/users/{userId}/cuttingToolAnalyses/{cuttingToolAnalysisId}` documents. This is used for authorization
 * checks, ensuring that only the owner can access the analysis case.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profiles.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own profile if the userId matches their auth.uid.
     * @allow (get, update, delete) - Authenticated user can get, update, or delete their own profile if the userId matches their auth.uid.
     * @deny (list) - Prevents listing all users.
     * @deny (create) - Prevents creating a user with an ID that doesn't match the authenticated user's ID.
     * @deny (update, delete) - Prevents updating or deleting a user profile if the user ID does not match the authenticated user's ID.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isOwner(userId) && resource.data.id == request.resource.data.id;
      allow delete: if isOwner(userId) && resource.data.id == userId;
    }

    /**
     * @description Enforces access control for cutting tool analysis cases.
     * @path /users/{userId}/cuttingToolAnalyses/{cuttingToolAnalysisId}
     * @allow (create) - Authenticated user can create a new analysis case under their user ID.
     * @allow (get, list, update, delete) - Authenticated user can get, list, update, or delete their own analysis cases.
     * @deny (create, update, delete) - Prevents creating, updating, or deleting analysis cases under another user's ID.
     * @principle Enforces document ownership for all operations on analysis cases.
     */
    match /users/{userId}/cuttingToolAnalyses/{cuttingToolAnalysisId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(userId) && resource.data.userId == request.resource.data.userId;
      allow delete: if isExistingOwner(userId) && resource.data.userId == userId;
    }
  }
}