
/**
 * @fileoverview Firestore Security Rules for Analizador de Costos de Corte application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for modifications but allows global read access
 * for key data like cutting tool analyses to promote knowledge sharing.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, including a 'role' field ('admin' or 'user').
 * - /cuttingToolAnalyses/{analysisId}: A global collection of all analysis cases.
 *   - Any authenticated user can read all cases.
 *   - Only the original creator ('userId' field) or an admin can update/delete a case.
 *
 * Key Security Decisions:
 * - User data is private.
 * - Cutting tool analyses are public to all logged-in users.
 * - Write/Delete permissions on analyses are restricted to owners and admins to maintain data integrity.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Determines if the requesting user is the owner of the document based on a 'userId' field.
     * @param resource The resource document being accessed.
     * @returns boolean
     */
    function isResourceOwner(resource) {
      return request.auth != null && request.auth.uid == resource.data.userId;
    }

    /**
     * @description Checks if the requesting user has the 'admin' role.
     * It fetches the user's profile from the /users collection.
     * @returns boolean
     */
    function isRequestingUserAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * @description Enforces access control for user profiles.
     * @path /users/{userId}
     * @allow (get, update) - Authenticated user can get/update their own profile. Admins can manage any profile.
     * @allow (create) - A new user can create their own profile. Admins can create new user profiles.
     * @deny (list, delete) - Prevents listing or deleting users.
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, update: if isOwner() || isRequestingUserAdmin();
      allow list: if false;
      allow create: if isRequestingUserAdmin() || (isOwner() && request.resource.data.role == 'user');
      allow delete: if false; // Protect against accidental deletion
    }

    /**
     * @description Enforces access control for the global cutting tool analysis collection.
     * @path /cuttingToolAnalyses/{analysisId}
     * @allow (get, list) - Any authenticated user can read any case.
     * @allow (create) - Any authenticated user can create a new case, ensuring they set themselves as the owner.
     * @allow (update, delete) - Only the original owner or an admin can update or delete a case.
     */
    match /cuttingToolAnalyses/{analysisId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isResourceOwner(resource) || isRequestingUserAdmin();
    }

    /**
     * @description Enforces access control for notifications.
     * @path /notifications/{notificationId}
     * @allow (read) - Any authenticated user can read notifications.
     * @allow (write) - Writes are disallowed from the client to prevent spam/abuse.
     */
    match /notifications/{notificationId} {
        allow read: if request.auth != null;
        allow write: if false; // Notifications should be created server-side or via controlled functions
    }
  }
}
