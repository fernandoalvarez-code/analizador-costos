
/**
 * @fileoverview Firestore Security Rules for Analizador de Costos de Corte application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for modifications but allows global read access
 * for key data like cutting tool analyses to promote knowledge sharing. It leverages
 * custom authentication tokens (claims) for role-based access control (RBAC) to ensure
 * scalability and offline compatibility.
 *
 * Data Structure & Auth Claims:
 * - /users/{userId}: Stores public user profiles. The 'role' is primarily read from the auth token.
 * - /cuttingToolAnalyses/{analysisId}: A global collection of all analysis cases.
 * - Custom Claim 'role': Each user's auth token contains a `role` claim ('admin' or 'user').
 *
 * Key Security Decisions:
 * - User data is private to the owner, but admins can read/write it.
 * - Role verification (`isAdmin`) is done via `request.auth.token.role`, which is fast, secure,
 *   and works offline, avoiding server-side `get()` calls in rules.
 * - Cutting tool analyses are public to all logged-in users.
 * - Write/Delete permissions on analyses are restricted to owners and admins.
 * - Update operations work offline by ensuring the `userId` field is immutable.
 * - Delete operations require an online connection to verify ownership securely.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the requesting user has the 'admin' role by reading custom claims from their auth token.
     * This method is fast, secure, and works offline.
     * @returns boolean
     */
    function isRequestingUserAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }
    
    /**
     * @description Enforces access control for user profiles.
     * @path /users/{userId}
     * @allow (get, update) - Authenticated user can get/update their own profile. Admins can manage any profile.
     * @allow (create) - A new user can create their own profile. Admins can create new user profiles.
     * @deny (list, delete) - Prevents listing or deleting users.
     */
    match /users/{userId} {
      function isSelf() {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, update: if isSelf() || isRequestingUserAdmin();
      allow list: if false;
      allow create: if isRequestingUserAdmin() || (isSelf() && request.resource.data.role == 'user');
      allow delete: if false; // Protect against accidental deletion
    }

    /**
     * @description Enforces access control for the global cutting tool analysis collection.
     * @path /cuttingToolAnalyses/{analysisId}
     * @allow (get, list) - Any authenticated user can read any case.
     * @allow (create) - Any authenticated user can create a new case, ensuring they set themselves as the owner.
     * @allow (update) - Only the original owner or an admin can update. The owner's userId cannot be changed. This rule works offline.
     * @allow (delete) - Only the original owner or an admin can delete. This rule requires an online connection to work.
     */
    match /cuttingToolAnalyses/{analysisId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Allow update if the user is an admin, OR if they are the owner and are not trying to change the owner.
      // This works offline for the owner because it doesn't need to read the existing document.
      allow update: if isRequestingUserAdmin() || 
                     (request.auth != null && request.resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId);

      // Allow delete if the user is an admin OR if they are the owner.
      // This requires reading the document, so it will only work online. Offline delete attempts will be denied
      // by the rules and queued by the SDK to retry on reconnection.
      allow delete: if isRequestingUserAdmin() || 
                     (request.auth != null && get(/databases/$(database)/documents/cuttingToolAnalyses/$(analysisId)).data.userId == request.auth.uid);
    }

    /**
     * @description Enforces access control for notifications.
     * @path /notifications/{notificationId}
     * @allow (read) - Any authenticated user can read notifications.
     * @allow (write) - Client-side writes are only allowed if the request comes from an admin (e.g., a stale case notification function).
     *                 For more security, this would typically be a Cloud Function.
     */
    match /notifications/{notificationId} {
        allow read: if request.auth != null;
        // Allow admins to create notifications. This is a temporary measure for the stale case checker.
        allow create: if isRequestingUserAdmin();
        allow update, delete: if false;
    }
  }
}
